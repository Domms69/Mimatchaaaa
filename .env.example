# ==========================================
# MiMatcha - Environment Variables
# ==========================================
# 
# Untuk Railway, set variabel berikut di dashboard:
#   Railway Settings → Variables
#
# DATABASE_URL akan otomatis terisi jika
# PostgreSQL addon sudah ditambahkan.
# ==========================================

# OpenRouter API Key — untuk deteksi uang AI
# Daftar: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Database — Railway akan mengisi DATABASE_URL otomatis
# dari PostgreSQL addon. Tidak perlu diisi manual.
# DATABASE_URL=postgresql://user:password@host:port/database
